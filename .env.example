# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gameleira_db

# Application
APP_NAME=Gameleira PHP System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Security
JWT_SECRET=your_jwt_secret_key_here_change_in_production
SESSION_TIMEOUT=3600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (Optional)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASSWORD=

# API Keys (Optional)
STRIPE_KEY=
PAYPAL_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
